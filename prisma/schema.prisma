generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String            @id @default(uuid())
  name             String
  description      String?           @db.Text
  imageUrl         String?
  type             ProductType       @default(REVENDA)
  price            Decimal           @db.Decimal(10, 2)
  cost             Decimal           @default(0) @db.Decimal(10, 2)
  operationalCost  Decimal           @default(0) @db.Decimal(10, 2)
  sku              String?
  isMadeToOrder    Boolean           @default(true)
  stock            Decimal           @default(0) @db.Decimal(10, 4)
  minStock         Decimal           @default(0) @db.Decimal(10, 4)
  unit             UnitType          @default(UN)
  isActive         Boolean           @default(true)
  isVisibleOnMenu  Boolean           @default(false)
  isPromotion      Boolean           @default(false)
  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  environmentId    String?
  environment      Environment?      @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id])
  
  goals            Goal[]
  orderItems       OrderItem[]
  saleItems        SaleItem[]
  stockMovements   StockMovement[]
  
  // Recursive Composition
  parentCompositions ProductComposition[] @relation("ParentProduct")
  childCompositions  ProductComposition[] @relation("ChildProduct")
  
  productionOrders ProductionOrder[]
  
  expirationDate   DateTime?
  trackExpiration  Boolean           @default(false)
  expirationReminderDate DateTime?

  suppliers        ProductSupplier[]
  stockEntries     StockEntry[]


  @@unique([sku, companyId])
}

model ProductComposition {
  id        String   @id @default(cuid())
  parentId  String
  childId   String
  quantity  Decimal  @db.Decimal(10, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  parent    Product  @relation("ParentProduct", fields: [parentId], references: [id], onDelete: Cascade)
  child     Product  @relation("ChildProduct", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

model Sale {
  id             String          @id @default(uuid())
  date           DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  companyId      String
  status         SaleStatus      @default(ACTIVE)
  userId         String?
  discountAmount Decimal         @default(0) @db.Decimal(10, 2)
  extraAmount    Decimal         @default(0) @db.Decimal(10, 2)
  adjustmentReason String?
  isEmployeeSale Boolean         @default(false)
  totalAmount    Decimal         @default(0) @db.Decimal(10, 2)
  tipAmount      Decimal         @default(0) @db.Decimal(10, 2)
  totalCost      Decimal         @default(0) @db.Decimal(10, 2)
  customerId     String?
  paymentMethod  PaymentMethod?
  orderId        String?         @unique
  company        Company         @relation(fields: [companyId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  order          Order?          @relation(fields: [orderId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@index([companyId, status, date])
  @@index([companyId, createdAt])
  @@index([customerId])
}

model SaleItem {
  id             String   @id @default(uuid())
  saleId         String
  productId      String
  unitPrice      Decimal  @db.Decimal(10, 2)
  quantity       Decimal  @db.Decimal(10, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  baseCost       Decimal  @default(0) @db.Decimal(10, 2) // SNAPSHOT: Custo do produto no momento da venda
  operationalCost Decimal @default(0) @db.Decimal(10, 2) // SNAPSHOT: Custo operacional no momento da venda
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(10, 2)
  totalCost      Decimal  @default(0) @db.Decimal(10, 2)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
  @@map("SaleProduct")
}

model User {
  id                   String            @id @default(cuid())
  name                 String?
  email                String            @unique
  emailVerified        DateTime?
  password             String?
  image                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  needsPasswordChange  Boolean           @default(false)
  phone                String?
  resetPasswordExpires DateTime?
  resetPasswordToken   String?           @unique
  sessionVersion       Int               @default(0)
  accounts             Account[]
  auditEvents          AuditEvent[]      @relation("UserAudits")
  createdGoals         Goal[]
  productionOrders     ProductionOrder[]
  sales                Sale[]
  sessions             Session[]
  stockMovements       StockMovement[]
  stockEntries         StockEntry[]
  userCompanies        UserCompany[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StockMovement {
  id              String            @id @default(uuid())
  type            StockMovementType
  stockBefore     Decimal           @db.Decimal(10, 4)
  stockAfter      Decimal           @db.Decimal(10, 4)
  productId       String?
  companyId       String
  userId          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  saleId          String?
  reason          String?
  quantityDecimal Decimal?          @db.Decimal(10, 4)
  orderId         String?
  unit            UnitType?
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  order           Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  sale           Sale?             @relation(fields: [saleId], references: [id], onDelete: SetNull)
  user            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([companyId])
}

model Company {
  id                     String              @id @default(cuid())
  name                   String
  createdAt              DateTime            @default(now())
  allowNegativeStock     Boolean             @default(false)
  expiresAt              DateTime?
  subscriptionStatus     SubscriptionStatus? @default(TRIALING)
  isBoletoPending        Boolean             @default(false)
  deletedAt              DateTime? // Soft delete flag
  plan                   String              @default("FREE")
  auditEvents            AuditEvent[]
  crmStages              CRMStage[]
  invitations            CompanyInvitation[]
  customers              Customer[]
  customerCategories     CustomerCategory[]
  goals                  Goal[]
  orders                 Order[]
  products               Product[]
  categories             Category[]
  productionOrders       ProductionOrder[]
  environments           Environment[]
  sales                  Sale[]
  stockMovements         StockMovement[]
  userCompanies          UserCompany[]
  checklists             Checklist[]
  checklistItems         ChecklistItem[]
  checklistTemplates     ChecklistTemplate[]
  notifications          Notification[]
  estimatedMonthlyVolume Int                @default(1000)
  enableOverheadInjection Boolean            @default(true)
  fixedExpenses          FixedExpense[]
  suppliers              Supplier[]
  stockEntries           StockEntry[]


  @@index([deletedAt])
}

model FixedExpense {
  id        String   @id @default(cuid())
  name      String
  value     Decimal  @db.Decimal(10, 2)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model CompanyInvitation {
  id        String           @id @default(uuid())
  email     String
  role      UserRole         @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  companyId String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([email, companyId, status])
}

model ProductionOrder {
  id          String   @id @default(cuid())
  productId   String
  companyId   String
  quantity    Int
  totalCost   Decimal  @default(0) @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
}

model AuditEvent {
  id              String         @id @default(cuid())
  type            AuditEventType
  companyId       String?
  actorId         String
  metadata        Json?
  createdAt       DateTime       @default(now())
  actorEmail      String?
  actorName       String?
  entityId        String?
  entityType      String?
  metadataVersion Int            @default(1)
  severity        AuditSeverity  @default(INFO)
  actor           User           @relation("UserAudits", fields: [actorId], references: [id])
  company         Company?       @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@index([type])
  @@index([entityType, entityId])
}

model Customer {
  id          String               @id @default(cuid())
  name        String
  email       String?
  phone       String?
  source      CustomerSource       @default(MANUAL)
  externalId  String?
  birthday    DateTime?
  birthdayReminderDate DateTime?
  notes       String?
  isActive    Boolean              @default(true)
  companyId   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  oldCategory CustomerCategoryEnum @default(LEAD)
  stageId     String?
  position    Int                  @default(0)
  company     Company              @relation(fields: [companyId], references: [id])
  stage       CRMStage?            @relation(fields: [stageId], references: [id], onDelete: SetNull)
  orders      Order[]
  sales       Sale[]
  categories  CustomerCategory[]   @relation("CustomerToCustomerCategory")
  checklists  Checklist[]

  @@unique([email, companyId])
  @@unique([phone, companyId])
  @@unique([externalId, source, companyId])
  @@index([companyId, stageId])
  @@index([companyId, stageId, position])
  @@index([companyId, birthday])
}

model CustomerCategory {
  id        String     @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  color     String?
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customers Customer[] @relation("CustomerToCustomerCategory")

  @@unique([name, companyId])
}

model CRMStage {
  id        String     @id @default(cuid())
  name      String
  order     Int        @default(0)
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customers Customer[]

  @@unique([name, companyId])
}

model Goal {
  id          String     @id @default(cuid())
  type        GoalType
  period      GoalPeriod @default(MONTHLY)
  targetValue Decimal    @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime?
  productId   String?
  companyId   String
  createdById String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  description String?
  name        String
  company     Company    @relation(fields: [companyId], references: [id])
  createdBy   User       @relation(fields: [createdById], references: [id])
  product     Product?   @relation(fields: [productId], references: [id])

  @@index([companyId, startDate, endDate])
  @@index([companyId, productId])
  @@index([companyId, type, isActive])
}

model Order {
  id            String          @id @default(cuid())
  orderNumber   Int             @default(autoincrement())
  status        OrderStatus     @default(PENDING)
  companyId     String
  customerId    String?
  tableNumber   String?
  notes         String?         @db.Text
  totalAmount    Decimal         @default(0) @db.Decimal(10, 2)
  discountAmount Decimal         @default(0) @db.Decimal(10, 2)
  extraAmount    Decimal         @default(0) @db.Decimal(10, 2)
  adjustmentReason String?
  isEmployeeSale Boolean         @default(false)
  hasServiceTax Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  company       Company         @relation(fields: [companyId], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  orderItems    OrderItem[]
  sale          Sale?
  stockMovements StockMovement[]

  @@index([companyId, status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Category {
  id         String    @id @default(cuid())
  name       String
  orderIndex Int       @default(0)
  icon       String?
  companyId  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([name, companyId])
}

model Environment {
  id         String    @id @default(cuid())
  name       String
  orderIndex Int       @default(0)
  companyId  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([name, companyId])
}

model Checklist {
  id          String          @id @default(cuid())
  title       String
  customerId  String
  companyId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]

  @@index([customerId])
  @@index([companyId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  title       String
  isChecked   Boolean   @default(false)
  order       Int       @default(0)
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  dueDate     DateTime?
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  name      String
  companyId String
  items     Json     // List of strings or simplified objects
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // Ex: 'EXPIRATION_ALERT', 'STOCK_ALERT', 'SYSTEM'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Supplier {
  id             String            @id @default(cuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  taxId          String?           // CNPJ ou CPF
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products       ProductSupplier[]
  stockEntries   StockEntry[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([name, companyId])
  @@index([companyId])
}

model ProductSupplier {
  productId      String
  supplierId     String
  supplierSku    String?
  lastCost       Decimal?          @db.Decimal(10, 2)
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier       Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
}

model StockEntry {
  id             String            @id @default(cuid())
  productId      String
  supplierId     String?
  userId         String?
  companyId      String
  quantity       Decimal           @db.Decimal(10, 4)
  unitCost       Decimal           @db.Decimal(10, 2)
  totalCost      Decimal           @db.Decimal(10, 2)
  batchNumber    String?
  expirationDate DateTime?
  invoiceNumber  String?
  createdAt      DateTime          @default(now())
  
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier       Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([supplierId])
  @@index([companyId])
}


enum SaleStatus {
  ACTIVE
  CANCELED
  DRAFT
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELED
  PAID
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum StockMovementType {
  SALE
  ADJUSTMENT
  MANUAL
  CANCEL
  PRODUCTION
  ORDER
  PURCHASE
  WASTE
}

enum ProductType {
  REVENDA
  PRODUCAO_PROPRIA
  COMBO
  INSUMO
}

enum UnitType {
  KG
  G
  L
  ML
  UN
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditEventType {
  OWNERSHIP_TRANSFERRED
  COMPANY_SOFT_DELETED
  COMPANY_RESTORED
  COMPANY_PERMANENTLY_DELETED
  MEMBER_INVITED
  MEMBER_REMOVED
  ROLE_UPDATED
  STOCK_ADJUSTED
  SALE_CANCELED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELED
  BILLING_REQUIRED
  CHECKOUT_STARTED
  SALE_CREATED
  SALE_UPDATED
  SALE_DELETED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  INGREDIENT_CREATED
  INGREDIENT_UPDATED
  INGREDIENT_DELETED
  INGREDIENT_STOCK_ADJUSTED
  CUSTOMER_STAGE_UPDATED
  CHECKLIST_ITEM_COMPLETED
}

enum CustomerCategoryEnum {
  LEAD
  REGULAR
  VIP
  INACTIVE
}

enum CustomerSource {
  MANUAL
  IFOOD
  WHATSAPP
  WEBSITE
  OTHER
  MENU
}

enum GoalType {
  GLOBAL
  PRODUCT
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}
