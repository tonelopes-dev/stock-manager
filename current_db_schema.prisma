generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuditEvent {
  id              String         @id
  type            AuditEventType
  companyId       String?
  actorId         String
  metadata        Json?
  createdAt       DateTime       @default(now())
  actorEmail      String?
  actorName       String?
  entityId        String?
  entityType      String?
  metadataVersion Int            @default(1)
  severity        AuditSeverity  @default(INFO)
  User            User           @relation(fields: [actorId], references: [id])
  Company         Company?       @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([type])
}

model CRMStage {
  id        String     @id
  name      String
  order     Int        @default(0)
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Customer  Customer[]

  @@unique([name, companyId])
}

model Checklist {
  id            String          @id
  title         String
  customerId    String
  companyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ChecklistItem ChecklistItem[]

  @@index([companyId])
  @@index([customerId])
}

model ChecklistItem {
  id          String    @id
  checklistId String
  title       String
  isChecked   Boolean   @default(false)
  order       Int       @default(0)
  companyId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  Company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model ChecklistTemplate {
  id        String  @id
  name      String
  companyId String
  items     Json
  Company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Company {
  id                     String              @id
  name                   String
  createdAt              DateTime            @default(now())
  allowNegativeStock     Boolean             @default(false)
  stripeCurrentPeriodEnd DateTime?
  stripeCustomerId       String?             @unique
  stripePriceId          String?
  stripeSubscriptionId   String?             @unique
  subscriptionStatus     SubscriptionStatus?
  deletedAt              DateTime?
  plan                   String              @default("FREE")
  isBoletoPending        Boolean             @default(false)
  stripeInvoiceUrl       String?
  AuditEvent             AuditEvent[]
  CRMStage               CRMStage[]
  Checklist              Checklist[]
  ChecklistItem          ChecklistItem[]
  ChecklistTemplate      ChecklistTemplate[]
  CompanyInvitation      CompanyInvitation[]
  Customer               Customer[]
  CustomerCategory       CustomerCategory[]
  Goal                   Goal[]
  Ingredient             Ingredient[]
  Order                  Order[]
  Product                Product[]
  ProductCategory        ProductCategory[]
  ProductionOrder        ProductionOrder[]
  Sale                   Sale[]
  StockMovement          StockMovement[]
  UserCompany            UserCompany[]

  @@index([deletedAt])
}

model CompanyInvitation {
  id        String           @id
  email     String
  role      UserRole         @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  companyId String
  createdAt DateTime         @default(now())
  updatedAt DateTime
  Company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([email, companyId, status])
}

model Customer {
  id               String               @id
  name             String
  email            String?
  phone            String?
  source           CustomerSource       @default(MANUAL)
  externalId       String?
  birthday         DateTime?
  notes            String?
  isActive         Boolean              @default(true)
  companyId        String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime
  oldCategory      CustomerCategoryEnum @default(LEAD)
  stageId          String?
  position         Int                  @default(0)
  Checklist        Checklist[]
  Company          Company              @relation(fields: [companyId], references: [id])
  CRMStage         CRMStage?            @relation(fields: [stageId], references: [id])
  Order            Order[]
  Sale             Sale[]
  CustomerCategory CustomerCategory[]

  @@unique([email, companyId])
  @@unique([externalId, source, companyId])
  @@unique([phone, companyId])
  @@index([companyId, birthday])
  @@index([companyId, stageId])
  @@index([companyId, stageId, position])
}

model CustomerCategory {
  id        String     @id
  name      String
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime
  color     String?
  Company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Customer  Customer[]

  @@unique([name, companyId])
}

model Goal {
  id          String     @id
  type        GoalType
  period      GoalPeriod @default(MONTHLY)
  targetValue Decimal    @db.Decimal(10, 2)
  startDate   DateTime
  endDate     DateTime?
  productId   String?
  companyId   String
  createdById String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  description String?
  name        String
  Company     Company    @relation(fields: [companyId], references: [id])
  User        User       @relation(fields: [createdById], references: [id])
  Product     Product?   @relation(fields: [productId], references: [id])

  @@index([companyId, productId])
  @@index([companyId, startDate, endDate])
  @@index([companyId, type, isActive])
}

model Ingredient {
  id            String          @id
  name          String
  unit          UnitType
  cost          Decimal         @db.Decimal(10, 4)
  stock         Decimal         @default(0) @db.Decimal(10, 4)
  minStock      Decimal         @default(0) @db.Decimal(10, 4)
  isActive      Boolean         @default(true)
  companyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Company       Company         @relation(fields: [companyId], references: [id])
  ProductRecipe ProductRecipe[]
  StockMovement StockMovement[]

  @@index([companyId])
}

model Order {
  id            String          @id
  orderNumber   Int             @default(autoincrement())
  status        OrderStatus     @default(PENDING)
  companyId     String
  customerId    String?
  tableNumber   String?
  notes         String?
  totalAmount   Decimal         @default(0) @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Company       Company         @relation(fields: [companyId], references: [id])
  Customer      Customer?       @relation(fields: [customerId], references: [id])
  OrderItem     OrderItem[]
  Sale          Sale?
  StockMovement StockMovement[]

  @@index([companyId, status])
}

model OrderItem {
  id        String   @id
  orderId   String
  productId String
  quantity  Decimal  @db.Decimal(10, 3)
  unitPrice Decimal  @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Product {
  id              String            @id
  name            String
  price           Decimal           @db.Decimal(10, 2)
  stock           Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  companyId       String
  category        String?
  cost            Decimal           @default(0) @db.Decimal(10, 2)
  minStock        Int               @default(0)
  sku             String?
  isActive        Boolean           @default(true)
  type            ProductType       @default(RESELL)
  description     String?
  imageUrl        String?
  isPromotion     Boolean           @default(false)
  isVisibleOnMenu Boolean           @default(false)
  Goal            Goal[]
  OrderItem       OrderItem[]
  Company         Company           @relation(fields: [companyId], references: [id])
  ProductRecipe   ProductRecipe[]
  ProductionOrder ProductionOrder[]
  SaleProduct     SaleProduct[]
  StockMovement   StockMovement[]
  ProductCategory ProductCategory[]

  @@unique([sku, companyId])
}

model ProductCategory {
  id         String    @id
  name       String
  icon       String?
  orderIndex Int       @default(0)
  companyId  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Product    Product[]

  @@unique([name, companyId])
}

model ProductRecipe {
  id           String     @id
  productId    String
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 4)
  unit         UnitType
  Ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  Product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
}

model ProductionOrder {
  id          String   @id
  productId   String
  companyId   String
  quantity    Int
  totalCost   Decimal  @default(0) @db.Decimal(10, 2)
  createdById String
  createdAt   DateTime @default(now())
  Company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [createdById], references: [id])
  Product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
}

model Sale {
  id             String          @id
  date           DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  companyId      String
  status         SaleStatus      @default(ACTIVE)
  userId         String?
  discountAmount Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal         @default(0) @db.Decimal(10, 2)
  totalCost      Decimal         @default(0) @db.Decimal(10, 2)
  customerId     String?
  paymentMethod  PaymentMethod?
  orderId        String?         @unique
  Company        Company         @relation(fields: [companyId], references: [id])
  Customer       Customer?       @relation(fields: [customerId], references: [id])
  Order          Order?          @relation(fields: [orderId], references: [id])
  User           User?           @relation(fields: [userId], references: [id])
  SaleProduct    SaleProduct[]
  StockMovement  StockMovement[]

  @@index([companyId, createdAt])
  @@index([companyId, status, date])
  @@index([customerId])
}

model SaleProduct {
  id             String   @id
  saleId         String
  productId      String
  unitPrice      Decimal  @db.Decimal(10, 2)
  quantity       Decimal  @db.Decimal(10, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  baseCost       Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(10, 2)
  totalCost      Decimal  @default(0) @db.Decimal(10, 2)
  Product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  Sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([saleId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id              String            @id
  type            StockMovementType
  stockBefore     Decimal           @db.Decimal(10, 4)
  stockAfter      Decimal           @db.Decimal(10, 4)
  productId       String?
  companyId       String
  userId          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  saleId          String?
  reason          String?
  ingredientId    String?
  quantityDecimal Decimal?          @db.Decimal(10, 4)
  orderId         String?
  Company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  Ingredient      Ingredient?       @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  Order           Order?            @relation(fields: [orderId], references: [id])
  Product         Product?          @relation(fields: [productId], references: [id], onDelete: Cascade)
  Sale            Sale?             @relation(fields: [saleId], references: [id])
  User            User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
}

model User {
  id                   String            @id
  name                 String?
  email                String            @unique
  emailVerified        DateTime?
  password             String?
  image                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime
  needsPasswordChange  Boolean           @default(false)
  phone                String?
  resetPasswordExpires DateTime?
  resetPasswordToken   String?           @unique
  sessionVersion       Int               @default(0)
  Account              Account[]
  AuditEvent           AuditEvent[]
  Goal                 Goal[]
  ProductionOrder      ProductionOrder[]
  Sale                 Sale[]
  Session              Session[]
  StockMovement        StockMovement[]
  UserCompany          UserCompany[]
}

model UserCompany {
  id        String   @id
  userId    String
  companyId String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum AuditEventType {
  OWNERSHIP_TRANSFERRED
  COMPANY_SOFT_DELETED
  COMPANY_RESTORED
  COMPANY_PERMANENTLY_DELETED
  MEMBER_INVITED
  MEMBER_REMOVED
  ROLE_UPDATED
  STOCK_ADJUSTED
  SALE_CANCELED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_CANCELED
  BILLING_REQUIRED
  CHECKOUT_STARTED
  SALE_CREATED
  SALE_UPDATED
  SALE_DELETED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum CustomerCategoryEnum {
  LEAD
  REGULAR
  VIP
  INACTIVE
}

enum CustomerSource {
  MANUAL
  IFOOD
  WHATSAPP
  WEBSITE
  OTHER
  MENU
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum GoalType {
  GLOBAL
  PRODUCT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELED
  PAID
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum ProductType {
  RESELL
  PREPARED
}

enum SaleStatus {
  ACTIVE
  CANCELED
  DRAFT
}

enum StockMovementType {
  SALE
  ADJUSTMENT
  MANUAL
  CANCEL
  PRODUCTION
  ORDER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum UnitType {
  KG
  G
  L
  ML
  UN
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}


