{
  "name": "stocky",
  "version": "1.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "stripe:dev": "concurrently \"next dev\" \"npm run stripe:listen\"",
    "stripe:listen": "npx -y @stripe/stripe-cli listen --forward-to localhost:3000/api/webhooks/stripe",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "prisma generate",
    "db:seed": "prisma db seed",
    "db:sync": "node scripts/sync-db.ts",
    "DANGER_DESTRUCTIVE_db:fresh": "prisma migrate reset --force",
    "db:warning": "echo 'WARNING: Do not run reset or fresh in production!'"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.19.1",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.20.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/react-window": "^1.8.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.441.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-safe-action": "^8.1.4",
    "next-themes": "^0.3.0",
    "prisma": "^5.19.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.53.0",
    "react-number-format": "^5.4.2",
    "react-window": "^2.2.7",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "sonner": "^1.5.0",
    "stripe": "^20.3.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.1.0",
    "zod": "^3.25.10"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^20",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "cross-spawn": "^7.0.5",
    "nanoid": "^3.3.8",
    "minimatch": "^9.0.5",
    "glob": "^11.0.1",
    "lodash": "^4.17.21",
    "ajv": "^6.14.0",
    "js-yaml": "^4.1.0",
    "@babel/runtime": "^7.26.10"
  }
}
